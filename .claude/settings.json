{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/enforce-alt.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/inject-meta-tags.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/inject-html-context.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/site-summary.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/validate-html.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/instructions-loaded.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A subagent just finished. Review the subagent's output and determine: (1) Did it produce meaningful output? (2) Were there any errors or failures? (3) Is the work complete and usable? Respond with JSON only: {\"ok\": true, \"reason\": \"...\"} if the work is complete, or {\"ok\": false, \"reason\": \"...\"} if it failed or produced no output. Do not include any text outside the JSON."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-links.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check-accessibility.py"
          }
        ]
      }
    ]
  }
}
